{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(node scripts/*)",
      "Bash(node packages/cli/src/index.mjs:*)",
      "Bash(npm run:*)",
      "Bash(npm test:*)",
      "Bash(pnpm:*)",
      "Bash(npx biome:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git tag:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git worktree:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo view:*)",
      "Bash(gh label:*)"
    ],
    "ask": [
      "Bash(gh repo delete:*)",
      "Bash(git push --force:*)"
    ]
  }
}
