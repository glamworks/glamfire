# Normalize all text to LF in the repo and on checkout for every OS, so the
# Biome formatter gate (LF) passes identically on macOS, Linux, and Windows.
# Without this, Windows checks out CRLF and `biome check` fails on package.json
# and every other tracked text file.
* text=auto eol=lf

# Binary assets: never touched by line-ending normalization.
*.png binary
*.jpg binary
*.ico binary
*.woff binary
*.woff2 binary
