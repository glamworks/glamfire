{
  "name": "glamfire",
  "version": "0.2.1",
  "private": true,
  "description": "The open harness for the last mile of AI. Own your context. Route your intelligence. Never rent your brain back.",
  "license": "Apache-2.0",
  "homepage": "https://glamworks.github.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glamworks/glamfire.git"
  },
  "bugs": "https://github.com/glamworks/glamfire/issues",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": ["packages/*"],
  "scripts": {
    "glam": "node packages/cli/src/index.mjs",
    "version:print": "node scripts/version.mjs",
    "version:bump": "node scripts/bump-version.mjs",
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "pretest": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "presmoke": "pnpm run build",
    "smoke": "node scripts/smoke.mjs",
    "build:npm": "bun scripts/build-npm.mjs",
    "build:binaries": "bun scripts/build-binaries.mjs",
    "sbom": "bun scripts/build-sbom.mjs",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "ai",
    "agent",
    "harness",
    "llm",
    "router",
    "glm",
    "fireworks",
    "context",
    "open-source",
    "model-agnostic",
    "last-mile"
  ],
  "dependencies": {
    "zod": "^4.4.3"
  }
}
